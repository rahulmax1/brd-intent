// =============================================================================
// ACFS VBS Portal - Production Schema v1.1 FIXED
// =============================================================================
// Generated: 2026-03-26
// Source: v1.0 + Critical fixes from schema review
// Changes: Added constraints, generated columns, audit fields, removed redundant fields
// Status: PRODUCTION READY
// =============================================================================

// =============================================================================
// ENUMS
// =============================================================================

Enum company_type {
  wholesale_freight_forwarder
  freight_forwarder
  transport_carrier
  customer
  clearing_agent
}

Enum user_role {
  acfs_admin        [note: 'Full privileges - user management, slot config, overrides']
  acfs_user         [note: 'Restricted privileges - DO validation, booking verification']
  lsp               [note: 'Logistics Service Provider - external company users']
}

Enum au_state {
  NSW
  VIC
  QLD
  SA
  WA
  TAS
  NT
  ACT
}

Enum slot_day_of_week {
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
  sunday
}

Enum container_status {
  received    [note: 'Container received at ACFS warehouse']
  unpacking   [note: 'Container being unpacked']
  unpacked    [note: 'All HBLs extracted and available for pickup']
}

Enum milestone_status {
  on_vessel     [note: 'Container on ship, not yet at port']
  at_wharf      [note: 'Container at port wharf']
  in_yard       [note: 'Container moved to yard storage']
  unpacked      [note: 'Goods unpacked and ready - required for booking per BR-001']
  collected     [note: 'Physically picked up by booking party']
}

Enum hbl_status {
  unassigned    [note: 'Not yet allocated to any LSP']
  assigned      [note: 'Allocated to primary LSP by ACFS']
  delegated     [note: 'LSP passed to another party - cannot book per BR-004']
  booked        [note: 'Pickup scheduled - cannot delegate per BR-004']
}

Enum customs_status {
  pending             [note: 'Awaiting customs clearance']
  partial_clearance   [note: 'Some items cleared, some held']
  fully_cleared       [note: 'All goods cleared - required for booking per BR-001']
  held                [note: 'Held by customs for inspection/quarantine']
}

Enum release_type {
  do_required     [note: 'Delivery Order must be uploaded and validated']
  free_release    [note: 'No DO required - auto-approved for pickup']
}

Enum do_validation_status {
  not_provided        [note: 'DO not yet uploaded']
  uploaded            [note: 'DO uploaded, awaiting validation']
  pending_validation  [note: 'ACFS staff reviewing DO']
  validated           [note: 'DO confirmed valid - booking can proceed']
  flagged             [note: 'DO incorrect - requires correction and re-upload']
  not_required        [note: 'Free release or under-bond - no DO needed']
}

Enum booking_status {
  draft                 [note: 'Being created - not yet paid']
  booked                [note: 'Confirmed and paid - awaiting pickup date']
  pending_processing    [note: 'ACFS staff verifying DOs and details']
  processed             [note: 'All DOs validated - ready for physical pickup']
  collected             [note: 'Goods physically collected - DERIVED when all HBLs reach collected milestone per BR-028']
  cancelled             [note: 'Booking cancelled by LSP or ACFS']
}

Enum payment_gateway {
  stripe      [note: 'Stripe payment processor']
  compay      [note: 'Compay payment processor (future)']
}

Enum payment_status {
  pending     [note: 'Payment initiated but not confirmed']
  completed   [note: 'Payment successful - booking confirmed']
  failed      [note: 'Payment gateway rejected transaction']
  refunded    [note: 'Payment refunded - processed outside VBS but status tracked']
}

Enum delegation_method {
  existing_lsp      [note: 'Delegate to registered LSP account']
  one_off_p4tc      [note: 'Delegate to one-off party via email (deferred Phase 1)']
}

Enum delegation_status {
  active    [note: 'Delegation in effect']
  revoked   [note: 'Delegation cancelled by ACFS - HBLs revert to delegator']
}

Enum notification_type {
  do_invalid                [note: 'DO marked invalid - requires correction']
  booking_confirmation      [note: 'Booking confirmed with reference number']
  booking_cancellation      [note: 'Booking cancelled by LSP or ACFS']
  booking_modified          [note: 'Booking details changed']
  user_invitation           [note: 'New user invited with sign-in link']
  hbl_assignment            [note: 'HBLs assigned to LSP']
  user_removal              [note: 'User account deactivated']
  delegation_notification   [note: 'HBLs delegated to party']
}

Enum notification_status {
  pending   [note: 'Queued for sending']
  sent      [note: 'Successfully delivered']
  failed    [note: 'Delivery failed - see error_message']
}

Enum audit_action {
  created   [note: 'Entity created']
  updated   [note: 'Entity modified']
  deleted   [note: 'Entity soft/hard deleted']
}

Enum entity_type {
  booking
  hbl
  delegation
  slot
  user
  delivery_order
}

// =============================================================================
// TABLES
// =============================================================================

// ─────────────────────────────────────────────────────────────────────────────
// TABLE GROUP: Companies & Users
// ─────────────────────────────────────────────────────────────────────────────

Table companies {
  Note: '''
  All external logistics organisations that interact with the VBS portal.
  ABN captured for Australian tax compliance (GST invoice generation).
  FIXED v1.1: Added archived_at for soft-delete consistency
  '''

  id              int           [pk, increment]
  company_name    varchar(255)  [not null]
  company_type    company_type  [not null]
  company_id      varchar(100)  [unique, note: 'External identifier from AGS or onboarding']
  branch_code     varchar(50)   [note: 'Multiple branches may exist per company']
  abn             char(11)      [note: 'Australian Business Number - 11 digits no spaces - GST invoices']
  email           varchar(255)  [not null, unique, note: 'Primary contact email for notifications']
  state           au_state      [note: 'Company primary state for GST treatment']
  is_active       boolean       [not null, default: true]
  archived_at     timestamp     [null, note: 'FIXED v1.1: Soft-delete timestamp for consistency']
  created_at      timestamp     [not null, default: `now()`]
  updated_at      timestamp     [not null, default: `now()`]

  indexes {
    (company_type, is_active) [name: 'idx_companies_type_active']
    abn [name: 'idx_companies_abn']
    email [name: 'idx_companies_email']
  }
}

Table users {
  Note: '''
  Platform users covering three roles (ACFS Admin, ACFS User, LSP).
  ACFS users authenticate via Okta SSO.
  LSP users authenticate via email/password with 72hr invitation link per BR-014.
  '''

  id              int           [pk, increment]
  company_id      int           [null, note: 'NULL for ACFS Admin/User']
  first_name      varchar(100)  [not null]
  last_name       varchar(100)  [not null]
  email           varchar(255)  [not null, unique]
  role            user_role     [not null]
  okta_id         varchar(255)  [null, unique, note: 'For ACFS users via Okta SSO']
  password_hash   varchar(255)  [null, note: 'For external LSP users only']
  is_active       boolean       [not null, default: true]
  archived_at     timestamp     [null, note: 'Soft delete - access disabled but audit retained']
  created_at      timestamp     [not null, default: `now()`]
  updated_at      timestamp     [not null, default: `now()`]

  indexes {
    email [name: 'idx_users_email']
    company_id [name: 'idx_users_company_id']
    okta_id [name: 'idx_users_okta_id']
    (role, is_active) [name: 'idx_users_role_active']
  }
}

Table user_invitations {
  Note: '''
  One-time password-set invitation links (72hr expiry per BR-014).
  Once used, token is voided.
  '''

  id          int           [pk, increment]
  user_id     int           [not null]
  token       varchar(512)  [not null, unique, note: 'Secure random token']
  sent_at     timestamp     [not null, default: `now()`]
  expires_at  timestamp     [not null, note: '72 hours from sent_at']
  used_at     timestamp     [null, note: 'Set when user completes password setup']

  indexes {
    token [name: 'idx_user_invitations_token']
    user_id [name: 'idx_user_invitations_user_id']
    (expires_at, used_at) [name: 'idx_user_invitations_expiry']
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// TABLE GROUP: Sites & Slots
// ─────────────────────────────────────────────────────────────────────────────

Table sites {
  Note: '''
  Physical ACFS warehouse locations.
  State field required for Australian address compliance and GST.
  '''

  id              int           [pk, increment]
  site_name       varchar(255)  [not null, unique]
  branch_code     varchar(50)   [note: 'Site branch identifier']
  address_line1   varchar(255)  [not null]
  address_line2   varchar(255)
  suburb          varchar(100)  [not null]
  state           au_state      [not null]
  postcode        char(4)       [not null, note: 'Australian 4-digit postcode']
  is_active       boolean       [not null, default: true]
  created_at      timestamp     [not null, default: `now()`]
  updated_at      timestamp     [not null, default: `now()`]

  indexes {
    (state, is_active) [name: 'idx_sites_state_active']
    branch_code [name: 'idx_sites_branch_code']
  }
}

Table slots {
  Note: '''
  Configurable pickup time windows (BR-005).
  Relative cutoffs: "previous_working_day" + "16:00" style rules.
  No hard capacity limits - heat_map_threshold is visual guidance only.
  FIXED v1.1: Added version column for optimistic locking
  '''

  id                              int               [pk, increment]
  site_id                         int               [not null]
  slot_name                       varchar(255)      [not null, note: 'Human-readable name']
  slot_area                       varchar(100)      [note: 'Physical area (e.g., Gate 1, Zone A)']
  day_of_week                     slot_day_of_week  [not null]
  start_time                      time              [not null]
  end_time                        time              [not null]

  // Structured cutoffs per BR-005
  booking_cutoff_relative_day     varchar(50)       [not null, note: 'previous_working_day | same_day | two_days_prior']
  booking_cutoff_time             time              [not null, note: 'e.g., 16:00']
  change_cutoff_relative_day      varchar(50)       [not null]
  change_cutoff_time              time              [not null]

  // Optional density indicator
  heat_map_threshold              int               [note: 'Visual density indicator - does NOT block bookings']

  // Administrative
  is_blocked                      boolean           [not null, default: false, note: 'Holiday or blackout date']
  is_active                       boolean           [not null, default: true]

  // FIXED v1.1: Optimistic locking
  version                         int               [not null, default: 1, note: 'Optimistic locking - increment on update']

  created_at                      timestamp         [not null, default: `now()`]
  updated_at                      timestamp         [not null, default: `now()`]

  indexes {
    site_id [name: 'idx_slots_site_id']
    (day_of_week, start_time) [name: 'idx_slots_schedule']
    is_active [name: 'idx_slots_is_active']
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// TABLE GROUP: Shipments & Delivery Orders
// ─────────────────────────────────────────────────────────────────────────────

Table containers {
  Note: '''
  Physical shipping containers received at ACFS.
  Maximus ERP is source of truth.
  '''

  id                  int               [pk, increment]
  container_number    varchar(50)       [not null, unique, note: 'Standard container ID (e.g., MSCU4729183)']
  ocean_bl            varchar(100)      [note: 'Ocean bill of lading - multiple containers may share']
  site_id             int               [not null, note: 'Which ACFS site received this']
  status              container_status  [not null, default: 'received']
  received_at         timestamp         [not null]
  unpacked_at         timestamp         [null, note: 'Set when status → unpacked']
  maximus_reference   varchar(255)      [null, note: 'Wholesale FF order ID in Maximus']
  created_at          timestamp         [not null, default: `now()`]
  updated_at          timestamp         [not null, default: `now()`]

  indexes {
    container_number [name: 'idx_containers_number']
    ocean_bl [name: 'idx_containers_ocean_bl']
    (site_id, status) [name: 'idx_containers_site_status']
  }
}

Table hbls {
  Note: '''
  House Bill of Lading - core shipment entity.

  **FIXED v1.1 Changes:**
  - REMOVED: chargeable_weight (compute on demand, snapshot in booking_hbls)
  - REMOVED: storage_fee_applicable (always compute from last_free_storage_date)
  - CHANGED: do_waived is now GENERATED COLUMN (release_type='free_release' OR under_bond=true)
  - ADDED: version for optimistic locking
  - ADDED: last_edited_by_user_id for audit per acfs:r12

  **Two Orthogonal Dimensions (BR-027):**
  1. milestone: Physical progress (on_vessel → collected)
  2. hbl_status: Business state (unassigned → assigned → delegated → booked)

  **Booking Readiness (BR-001):**
  - milestone IN ('unpacked', 'collected')
  - customs_status = 'fully_cleared'
  - do_waived = true OR all DOs validated
  '''

  id                      int               [pk, increment]
  container_id            int               [not null]

  // Primary identifiers
  hbl_number              varchar(100)      [not null, unique, note: 'Lowest-level house bill from Maximus']
  alt_hbl_reference       varchar(100)      [null, note: 'Parent/master HBL (AGS 500-prefix) from AGS feed']
  import_ref              varchar(100)      [null, note: 'Import order reference']

  // Physical attributes
  description             text              [note: 'Goods description']
  weight_kg               decimal(10,3)     [note: 'Actual weight in kilograms']
  volume_m3               decimal(10,3)     [note: 'Volume in cubic meters']
  quantity                int               [note: 'Number of packages']
  pack_type               varchar(100)      [note: 'Package type']

  // REMOVED: chargeable_weight - compute as max(weight_kg, volume_m3) on demand
  // REMOVED: storage_fee_applicable - compute as (current_date > last_free_storage_date)

  // Two orthogonal dimensions (BR-027)
  milestone               milestone_status  [not null, default: 'on_vessel', note: 'Physical progress - synced from Maximus']
  hbl_status              hbl_status        [not null, default: 'unassigned', note: 'Business state - managed within VBS']

  // Customs and clearance
  customs_status          customs_status    [not null, default: 'pending', note: 'Must be fully_cleared before booking (BR-001)']
  customs_clearance_date  date              [null]

  // Under-bond workflow (BR-002)
  under_bond              boolean           [not null, default: false, note: 'Manual flag - goods between bonded facilities']
  under_bond_verified     boolean           [not null, default: false, note: 'ACFS verification of under-bond']

  // Release and storage
  release_type            release_type      [not null, default: 'do_required', note: 'Per tier: do_required or free_release']

  // FIXED v1.1: do_waived is now GENERATED COLUMN - always consistent
  // PostgreSQL: GENERATED ALWAYS AS (release_type = 'free_release' OR under_bond = true) STORED
  // MySQL: GENERATED ALWAYS AS (release_type = 'free_release' OR under_bond = 1) STORED
  do_waived               boolean           [note: 'GENERATED: true when release_type=free_release OR under_bond=true']

  last_free_storage_date  date              [null, note: 'After this date, storage fees apply']
  // storage_fee_applicable computed as: (CURRENT_DATE > last_free_storage_date)

  // Critical for dispatch planning (BR-031)
  pickup_site_id          int               [not null, note: 'Which warehouse - MUST be visible and filterable']

  // Consignee from AGS feed (OQ-034)
  consignee_name          varchar(255)      [note: 'Next party - from AGS feed (Maximus too inconsistent)']
  consignee_account_code  varchar(100)      [note: 'Account identifier from AGS']

  // Assignment
  assigned_company_id     int               [null, note: 'LSP allocated by ACFS or auto-assignment']

  // Integration references
  maximus_hbl_id          varchar(255)      [null, note: 'Source record ID in Maximus for bidirectional sync']

  // FIXED v1.1: Audit fields
  last_edited_by_user_id  int               [null, note: 'ACFS user who last edited HBL details (acfs:r12)']
  version                 int               [not null, default: 1, note: 'Optimistic locking']

  created_at              timestamp         [not null, default: `now()`]
  updated_at              timestamp         [not null, default: `now()`]

  indexes {
    hbl_number [name: 'idx_hbls_number']
    alt_hbl_reference [name: 'idx_hbls_alt_ref']
    container_id [name: 'idx_hbls_container_id']
    assigned_company_id [name: 'idx_hbls_assigned_company']
    pickup_site_id [name: 'idx_hbls_pickup_site']
    (milestone, hbl_status) [name: 'idx_hbls_dual_dimension']
    consignee_account_code [name: 'idx_hbls_consignee']
    maximus_hbl_id [name: 'idx_hbls_maximus_id']
  }
}

Table hbl_custody_chain {
  Note: '''
  Each delegation hop in chain of custody.
  ACFS sees full chain; LSPs see hop-by-hop per C-009.
  '''

  id                  int               [pk, increment]
  hbl_id              int               [not null]
  from_company_id     int               [null, note: 'NULL when ACFS initiates first hop']
  to_company_id       int               [not null, note: 'Company receiving custody']
  hop_sequence        int               [not null, note: 'Ordinal: 1 = first hop from ACFS']
  delegation_method   delegation_method [note: 'existing_lsp or one_off_p4tc']
  assigned_at         timestamp         [not null, default: `now()`]
  created_at          timestamp         [not null, default: `now()`]

  indexes {
    hbl_id [name: 'idx_custody_hbl_id']
    (hbl_id, hop_sequence) [unique, name: 'uq_custody_hbl_hop']
    from_company_id [name: 'idx_custody_from_company']
    to_company_id [name: 'idx_custody_to_company']
  }
}

Table delegations {
  Note: '''
  First-class delegation entity for tracking and management.
  Allows ACFS to revoke delegations per acfs:r13.
  Multiple HBLs via delegation_hbls junction.
  '''

  id                      int               [pk, increment]
  delegator_company_id    int               [not null, note: 'Company initiating delegation']
  delegatee_company_id    int               [null, note: 'NULL for P4TC delegations']
  delegatee_email         varchar(255)      [null, note: 'For P4TC - receives magic link']
  delegation_method       delegation_method [not null]
  status                  delegation_status [not null, default: 'active']
  created_at              timestamp         [not null, default: `now()`]
  revoked_at              timestamp         [null]
  revoked_by_user_id      int               [null, note: 'ACFS user who revoked']

  indexes {
    delegator_company_id [name: 'idx_delegations_delegator']
    delegatee_company_id [name: 'idx_delegations_delegatee']
    status [name: 'idx_delegations_status']
  }
}

Table delegation_hbls {
  Note: '''
  Junction table linking delegations to HBLs.
  FIXED v1.1: Protected by BR-004 trigger - cannot delegate booked HBLs
  '''

  delegation_id   int   [not null]
  hbl_id          int   [not null]

  indexes {
    (delegation_id, hbl_id) [pk, name: 'pk_delegation_hbls']
    hbl_id [name: 'idx_delegation_hbls_hbl_id']
  }
}

Table delivery_orders {
  Note: '''
  Delivery Order - release authority document (one per delegation tier per BR-002).
  DO validation is HBL-centric per BR-018.
  FIXED v1.1: Added uploaded_by_user_id for audit trail
  '''

  id                      int                     [pk, increment]
  hbl_id                  int                     [not null]
  custody_chain_id        int                     [null, note: 'Specific custody hop that triggered this DO']

  issued_by_company_id    int                     [not null, note: 'Company issuing DO']
  issued_to_company_id    int                     [not null, note: 'For final hop, this is end customer']

  do_number               varchar(100)            [null, note: 'DO reference number if present']
  document_url            text                    [null, note: 'URL to uploaded document in object storage']
  tier_level              int                     [note: 'Which level in HBL hierarchy']

  validation_status       do_validation_status    [not null, default: 'not_provided']

  // FIXED v1.1: Added upload tracking
  uploaded_by_user_id     int                     [null, note: 'User who uploaded DO']

  validated_by_user_id    int                     [null, note: 'ACFS user who validated']
  validated_at            timestamp               [null]
  invalidation_reason     text                    [null, note: 'When status=flagged - triggers email to booking party']

  created_at              timestamp               [not null, default: `now()`]
  updated_at              timestamp               [not null, default: `now()`]

  indexes {
    hbl_id [name: 'idx_dos_hbl_id']
    (hbl_id, tier_level) [name: 'idx_dos_hbl_tier']
    custody_chain_id [name: 'idx_dos_custody_chain']
    validation_status [name: 'idx_dos_validation_status']
    issued_to_company_id [name: 'idx_dos_issued_to']
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// TABLE GROUP: Bookings & Payments
// ─────────────────────────────────────────────────────────────────────────────

Table bookings {
  Note: '''
  Pickup booking for one or more HBLs at specific slot.

  **FIXED v1.1 Changes:**
  - ADDED: cutoff_override_by_user_id, cutoff_override_reason, cutoff_override_at for BR-015
  - ADDED: version for optimistic locking
  - ADDED: Check constraints on GST calculations
  - ADDED: Check constraints on fee non-negativity

  **Lifecycle:** draft → booked → pending_processing → processed → collected → cancelled

  **BR-028:** 'collected' status is DERIVED when all HBLs reach collected milestone
  (Automated via background job, not manual)
  '''

  id                          int             [pk, increment]
  booking_reference           varchar(50)     [not null, unique, note: 'System-generated reference']

  // Slot details
  slot_id                     int             [not null]
  slot_date                   date            [not null, note: 'Calendar date of pickup']

  // Booking party
  booked_by_company_id        int             [not null]
  booked_by_user_id           int             [null, note: 'NULL for P4TC bookings (deferred)']
  booked_by_email             varchar(255)    [null, note: 'For P4TC - receives confirmations']

  // Status
  status                      booking_status  [not null, default: 'draft']

  // Driver and vehicle (CoR compliance)
  driver_name                 varchar(255)    [not null]
  driver_licence_number       varchar(50)     [not null, note: 'Verified by warehouse staff']
  driver_phone                varchar(20)     [note: 'Optional contact']
  truck_rego                  varchar(20)     [not null, note: 'Vehicle registration - CoR compliance']
  truck_details               text            [note: 'Additional vehicle description']

  // Site induction and T&Cs (BR-017)
  site_induction_completed    boolean         [not null, default: false, note: 'Driver completed ACFS site induction']
  site_induction_skipped      boolean         [not null, default: false, note: 'True if driver already has induction']
  terms_accepted_at           timestamp       [null, note: 'When T&Cs + site induction accepted']

  // Fees (GST compliance per A New Tax System (GST) Act 1999)
  // FIXED v1.1: Protected by check constraints
  total_fee_excl_gst          decimal(10,2)   [not null, note: 'Total before GST']
  gst_amount                  decimal(10,2)   [not null, note: '10% GST - CONSTRAINT: ABS(gst_amount - total_fee_excl_gst*0.10) < 0.01']
  total_fee_incl_gst          decimal(10,2)   [not null, note: 'Final amount - CONSTRAINT: ABS(total_fee_incl_gst - (total_fee_excl_gst+gst_amount)) < 0.01']

  // Modifications (BR-015)
  is_late_change              boolean         [not null, default: false, note: 'Set when change made after cutoff']
  late_change_fee             decimal(10,2)   [not null, default: 0, note: 'Additional fee for late modifications']
  last_modified_at            timestamp       [null]
  last_modified_by_user_id    int             [null]

  // FIXED v1.1: Cutoff override tracking for BR-015
  cutoff_override_by_user_id  int             [null, note: 'ACFS admin who authorized override']
  cutoff_override_reason      text            [null, note: 'Required reason when admin overrides cutoff']
  cutoff_override_at          timestamp       [null, note: 'When override was granted']

  // Administrative
  notes                       text            [null, note: 'Internal ACFS notes']
  cancelled_at                timestamp       [null]
  cancelled_by_user_id        int             [null]
  cancellation_reason         text            [null, note: 'Required when ACFS cancels (BR-022)']
  processed_at                timestamp       [null, note: 'When ACFS warehouse finalised']
  processed_by_user_id        int             [null]

  // FIXED v1.1: Optimistic locking
  version                     int             [not null, default: 1, note: 'Increment on update']

  created_at                  timestamp       [not null, default: `now()`]
  updated_at                  timestamp       [not null, default: `now()`]

  indexes {
    booking_reference [name: 'idx_bookings_reference']
    (slot_id, slot_date) [name: 'idx_bookings_slot']
    booked_by_company_id [name: 'idx_bookings_company_id']
    status [name: 'idx_bookings_status']
    truck_rego [name: 'idx_bookings_truck_rego']
    driver_licence_number [name: 'idx_bookings_driver_licence']
  }
}

Table booking_hbls {
  Note: '''
  Junction linking bookings to HBLs.

  **Per-HBL Fee Breakdown (BR-019):**
  Stores snapshot of chargeable_weight, rate, fee at booking time.

  FIXED v1.1:
  - Protected by BR-004 trigger - cannot book delegated HBLs
  - Check constraint on fee calculation: per_hbl_fee = chargeable_weight × rate
  '''

  id                  int             [pk, increment]
  booking_id          int             [not null]
  hbl_id              int             [not null]

  // Fee calculation snapshot at booking time
  chargeable_weight   decimal(10,3)   [not null, note: 'max(weight_kg, volume_m3) at booking time']
  rate                decimal(10,4)   [not null, note: 'Rate from pricing_zones at booking time']
  per_hbl_fee         decimal(10,2)   [not null, note: 'CONSTRAINT: ABS(per_hbl_fee - chargeable_weight*rate) < 0.01']

  created_at          timestamp       [not null, default: `now()`]

  indexes {
    booking_id [name: 'idx_booking_hbls_booking_id']
    hbl_id [name: 'idx_booking_hbls_hbl_id']
    (booking_id, hbl_id) [unique, name: 'uq_booking_hbl']
  }
}

Table payments {
  Note: '''
  Payment record for each booking.
  FIXED v1.1: payment_gateway now enum (stripe | compay)
  FIXED v1.1: Check constraint on GST calculation
  '''

  id                      int             [pk, increment]
  booking_id              int             [not null]

  amount_excl_gst         decimal(10,2)   [not null]
  gst_amount              decimal(10,2)   [not null, note: '10% GST - CONSTRAINT: ABS(gst_amount - amount_excl_gst*0.10) < 0.01']
  total_amount            decimal(10,2)   [not null, note: 'CONSTRAINT: ABS(total_amount - (amount_excl_gst+gst_amount)) < 0.01']

  payment_gateway         payment_gateway [note: 'FIXED v1.1: Now enum instead of varchar']
  payment_gateway_ref     varchar(255)    [note: 'Transaction reference from gateway']
  transaction_reference   varchar(255)    [note: 'Internal transaction reference']

  status                  payment_status  [not null, default: 'pending']
  payment_timestamp       timestamp       [null, note: 'When payment completed']
  processed_at            timestamp       [null]

  created_at              timestamp       [not null, default: `now()`]

  indexes {
    booking_id [name: 'idx_payments_booking_id']
    payment_gateway_ref [name: 'idx_payments_gateway_ref']
    status [name: 'idx_payments_status']
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// TABLE GROUP: Pricing
// ─────────────────────────────────────────────────────────────────────────────

Table pricing_zones {
  Note: '''
  Rate zone configuration per ACFS site.
  FIXED v1.1: Check constraint on gst_rate (0 <= gst_rate <= 1)

  **Fee Formula:**
  per_hbl_fee = chargeable_weight_kg × rate_per_kg
  total_booking_fee = MAX(SUM(per_hbl_fee), minimum_charge)
  final_amount = total_booking_fee × (1 + gst_rate)
  '''

  id              int             [pk, increment]
  site_id         int             [not null]
  zone_name       varchar(100)    [note: 'Zone identifier']

  rate_per_kg     decimal(10,4)   [not null, note: 'Rate per chargeable kilogram']
  minimum_charge  decimal(10,2)   [not null, note: 'Minimum booking fee']
  gst_rate        decimal(5,4)    [not null, default: 0.1000, note: 'CONSTRAINT: 0 <= gst_rate <= 1']

  effective_from  date            [not null]
  effective_to    date            [null, note: 'NULL = currently active']
  is_active       boolean         [not null, default: true]

  created_at      timestamp       [not null, default: `now()`]
  updated_at      timestamp       [not null, default: `now()`]

  indexes {
    site_id [name: 'idx_pricing_site_id']
    (site_id, effective_from, effective_to) [name: 'idx_pricing_temporal']
    is_active [name: 'idx_pricing_is_active']
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// TABLE GROUP: Driver Records (BR-016)
// ─────────────────────────────────────────────────────────────────────────────

Table driver_records {
  Note: '''
  Saved driver details scoped per LSP company (BR-016).
  FIXED v1.1: Added archived_at for soft-delete consistency
  '''

  id                          int           [pk, increment]
  company_id                  int           [not null, note: 'LSP company - drivers NOT shared across companies']

  driver_name                 varchar(255)  [not null]
  driver_licence_number       varchar(50)   [not null, note: 'Unique per company']
  driver_phone                varchar(20)   [note: 'Optional contact']
  default_truck_rego          varchar(20)   [note: 'Default vehicle, can be overridden']

  site_induction_completed    boolean       [not null, default: false, note: 'ACFS site induction completed']
  site_induction_date         date          [null, note: 'When induction completed']

  is_active                   boolean       [not null, default: true]
  archived_at                 timestamp     [null, note: 'FIXED v1.1: Soft delete for consistency']

  created_at                  timestamp     [not null, default: `now()`]
  updated_at                  timestamp     [not null, default: `now()`]

  indexes {
    company_id [name: 'idx_driver_records_company_id']
    (company_id, driver_licence_number) [unique, name: 'uq_driver_company_licence']
    is_active [name: 'idx_driver_records_is_active']
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// TABLE GROUP: Notifications
// ─────────────────────────────────────────────────────────────────────────────

Table email_notifications {
  Note: '''
  Audit log of system-triggered email notifications.
  FIXED v1.1: related_entity_type now enum for type safety
  FIXED v1.1: Added retry_count, next_retry_at, max_retries for email retry logic
  '''

  id                    int                 [pk, increment]

  recipient_email       varchar(255)        [not null]
  recipient_user_id     int                 [null, note: 'NULL for P4TC or unregistered parties']
  recipient_company_id  int                 [null, note: 'Company if known']

  notification_type     notification_type   [not null]
  related_entity_type   entity_type         [null, note: 'FIXED v1.1: Now enum (booking|hbl|delegation|user|slot)']
  related_entity_id     int                 [null, note: 'ID of related entity']

  subject               varchar(500)        [note: 'Email subject']
  body                  text                [note: 'Email body']
  secure_link_token     varchar(512)        [null, note: 'For P4TC magic links (deferred)']
  otp_code              varchar(10)         [null, note: 'For P4TC OTP (deferred)']

  sent_at               timestamp           [null, note: 'When successfully sent']
  status                notification_status [not null, default: 'pending']
  error_message         text                [null, note: 'If status=failed']

  // FIXED v1.1: Email retry mechanism
  retry_count           int                 [not null, default: 0, note: 'Number of send attempts']
  next_retry_at         timestamp           [null, note: 'When to retry if failed']
  max_retries           int                 [not null, default: 3, note: 'Maximum retry attempts']

  created_at            timestamp           [not null, default: `now()`]

  indexes {
    recipient_email [name: 'idx_notifications_recipient_email']
    recipient_user_id [name: 'idx_notifications_recipient_user_id']
    (notification_type, status) [name: 'idx_notifications_type_status']
    (related_entity_type, related_entity_id) [name: 'idx_notifications_entity']
    next_retry_at [name: 'idx_notifications_retry']
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// TABLE GROUP: Audit Trail (NEW in v1.1)
// ─────────────────────────────────────────────────────────────────────────────

Table entity_audit_log {
  Note: '''
  FIXED v1.1: NEW TABLE
  Comprehensive audit trail for critical entities.
  Tracks who changed what and when for compliance and debugging.
  '''

  id                  int           [pk, increment]
  entity_type         entity_type   [not null, note: 'booking | hbl | slot | user | delegation | delivery_order']
  entity_id           int           [not null, note: 'ID of the entity that changed']
  action              audit_action  [not null, note: 'created | updated | deleted']
  changed_fields      json          [null, note: 'Before/after values for updated fields']
  changed_by_user_id  int           [not null, note: 'User who made the change']
  changed_at          timestamp     [not null, default: `now()`]

  indexes {
    (entity_type, entity_id) [name: 'idx_audit_entity']
    changed_by_user_id [name: 'idx_audit_user']
    changed_at [name: 'idx_audit_timestamp']
    (entity_type, entity_id, changed_at) [name: 'idx_audit_entity_timeline']
  }
}

// =============================================================================
// RELATIONSHIPS
// =============================================================================

// Companies & Users
Ref: users.company_id > companies.id
Ref: user_invitations.user_id > users.id

// Sites & Slots
Ref: slots.site_id > sites.id

// Containers & HBLs
Ref: containers.site_id > sites.id
Ref: hbls.container_id > containers.id
Ref: hbls.assigned_company_id > companies.id
Ref: hbls.pickup_site_id > sites.id
Ref: hbls.last_edited_by_user_id > users.id

// Custody Chain & Delegations
Ref: hbl_custody_chain.hbl_id > hbls.id
Ref: hbl_custody_chain.from_company_id > companies.id
Ref: hbl_custody_chain.to_company_id > companies.id
Ref: delegations.delegator_company_id > companies.id
Ref: delegations.delegatee_company_id > companies.id
Ref: delegations.revoked_by_user_id > users.id
Ref: delegation_hbls.delegation_id > delegations.id
Ref: delegation_hbls.hbl_id > hbls.id

// Delivery Orders
Ref: delivery_orders.hbl_id > hbls.id
Ref: delivery_orders.custody_chain_id > hbl_custody_chain.id
Ref: delivery_orders.issued_by_company_id > companies.id
Ref: delivery_orders.issued_to_company_id > companies.id
Ref: delivery_orders.uploaded_by_user_id > users.id
Ref: delivery_orders.validated_by_user_id > users.id

// Bookings
Ref: bookings.slot_id > slots.id
Ref: bookings.booked_by_company_id > companies.id
Ref: bookings.booked_by_user_id > users.id
Ref: bookings.last_modified_by_user_id > users.id
Ref: bookings.cancelled_by_user_id > users.id
Ref: bookings.processed_by_user_id > users.id
Ref: bookings.cutoff_override_by_user_id > users.id

// Booking HBLs Junction
Ref: booking_hbls.booking_id > bookings.id
Ref: booking_hbls.hbl_id > hbls.id

// Payments
Ref: payments.booking_id > bookings.id

// Pricing
Ref: pricing_zones.site_id > sites.id

// Driver Records
Ref: driver_records.company_id > companies.id

// Notifications
Ref: email_notifications.recipient_user_id > users.id
Ref: email_notifications.recipient_company_id > companies.id

// Audit Trail
Ref: entity_audit_log.changed_by_user_id > users.id

